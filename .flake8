[flake8]
max-line-length = 88

extend-ignore =
    E501,
    W503,
    E203,

per-file-ignores =
    */__init__.py: F401
    alembic/versions/*.py: E501,F401

exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    alembic,
    static,
    dist,
    build,
    reports,
    docs,
    *.egg-info

max-complexity = 43
